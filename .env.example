# ========================================
# ENVIRONMENT CONFIGURATION EXAMPLE
# Copy this to .env and fill in your values
# ========================================

# ========== SERVER CONFIG ==========
NODE_ENV=development
PORT=8080
API_URL=http://localhost:8080

# ========== AZURE SQL DATABASE ==========
SQL_SERVER=supplychaindb.database.windows.net
SQL_DATABASE=SupplyChainDB
SQL_USER=dbadmin
SQL_PASSWORD=YourSecurePassword123!
SQL_ENCRYPT=true
SQL_TRUST_CERTIFICATE=false

# ========== AZURE COSMOS DB ==========
COSMOS_ENDPOINT=https://supplychaincosmos.documents.azure.com:443/
COSMOS_KEY=your_cosmos_primary_key_here
COSMOS_DATABASE=InventoryDB

# ========== AZURE CACHE FOR REDIS ==========
REDIS_HOST=supplychainredis.redis.cache.windows.net
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_access_key_here
REDIS_TLS=true
REDIS_TIMEOUT=5000

# ========== AZURE STORAGE ==========
STORAGE_ACCOUNT_NAME=supplychainstore
STORAGE_ACCOUNT_KEY=your_storage_account_key_here
STORAGE_CONTAINER_NAME=documents

# ========== AZURE KEY VAULT ==========
KEYVAULT_URL=https://supplychainvault.vault.azure.net/
KEYVAULT_TENANT_ID=your_azure_tenant_id
KEYVAULT_CLIENT_ID=your_azure_client_id
KEYVAULT_CLIENT_SECRET=your_azure_client_secret

# ========== JWT AUTHENTICATION ==========
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# ========== SENDGRID EMAIL ==========
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@supplychainapp.com
SENDGRID_FROM_NAME=Supply Chain App

# ========== STRIPE PAYMENT ==========
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ========== AZURE APPLICATION INSIGHTS ==========
APPINSIGHTS_INSTRUMENTATION_KEY=your_app_insights_key
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=your_key_here;IngestionEndpoint=https://eastus-1.in.applicationinsights.azure.com/

# ========== LOGGING ==========
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_DIR=./logs

# ========== CORS CONFIGURATION ==========
CORS_ORIGIN=http://localhost:3000,https://supplychainapp.azurewebsites.net
CORS_CREDENTIALS=true

# ========== API RATE LIMITING ==========
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========== DATABASE CONNECTION POOL ==========
POOL_MIN=10
POOL_MAX=50
POOL_IDLE_TIMEOUT=30000

# ========== CACHE SETTINGS ==========
CACHE_DEFAULT_TTL=300
CACHE_INVENTORY_TTL=300
CACHE_REPORT_TTL=3600
CACHE_SESSION_TTL=900

# ========== CRON JOBS ==========
ENABLE_DEMAND_FORECAST=true
FORECAST_SCHEDULE=0 2 * * *
ENABLE_INVENTORY_SYNC=true
INVENTORY_SYNC_SCHEDULE=*/30 * * * *

# ========== FEATURE FLAGS ==========
FEATURE_AI_RECOMMENDATIONS=true
FEATURE_REAL_TIME_TRACKING=true
FEATURE_AUTOMATED_REORDERING=true
FEATURE_PREDICTIVE_ANALYTICS=true

# ========== EXTERNAL INTEGRATIONS ==========
WEATHER_API_KEY=your_weather_api_key
MAPS_API_KEY=your_google_maps_api_key
SHIPPING_CARRIER_API_KEY=your_shipping_api_key

# ========== ENVIRONMENT SPECIFIC ==========
ENVIRONMENT=development
DEPLOYMENT_REGION=eastus
INSTANCE_ID=api-instance-1
