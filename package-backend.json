{
  "name": "supply-chain-api",
  "version": "1.0.0",
  "description": "Enterprise Supply Chain Management Application API powered by Microsoft Azure",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "migrate": "node migrations/run.js",
    "seed": "node database/seed.js",
    "build": "echo 'Build complete'",
    "deploy": "az webapp up --resource-group SupplyChainRG --name supply-chain-api",
    "docker:build": "docker build -t supply-chain-api:latest .",
    "docker:push": "docker push supplychainacr.azurecr.io/supply-chain-api:latest"
  },
  "keywords": [
    "supply-chain",
    "inventory",
    "orders",
    "logistics",
    "azure"
  ],
  "author": "Your Name",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.0",
    "mssql": "^9.2.0",
    "redis": "^4.6.11",
    "uuid": "^9.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "joi": "^17.10.2",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "@azure/identity": "^3.3.1",
    "@azure/keyvault-secrets": "^4.7.0",
    "@azure/storage-blob": "^3.22.3",
    "@azure/cosmos": "^3.21.0",
    "@azure/monitor-opentelemetry": "^1.2.0",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.7",
    "stripe": "^13.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.52.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.0.3",
    "@types/node": "^20.9.0"
  }
}
